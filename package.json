  "repository": {
    "type": "git",
    "url": "git+https://github.com/Csevav/ai-usage-dashboard.git"
  },
  "bin": {
    "ai-usage-dashboard": "./bin/ai-usage-dashboard.js",
    "ai-usage-dashboard-daemon": "./bin/ai-usage-dashboard-daemon.js"
