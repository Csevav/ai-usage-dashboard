#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export AI_USAGE_DASHBOARD_HOME="${AI_USAGE_DASHBOARD_HOME:-${HOME}/.ai-usage-dashboard}"

exec python3 "${SCRIPT_DIR}/scripts/build_dashboard.py" --source-dir "${SCRIPT_DIR}" --home "${AI_USAGE_DASHBOARD_HOME}" "$@"
